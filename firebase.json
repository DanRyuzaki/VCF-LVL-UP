{
  "firestore": {
    "database": "(default)",
    "location": "asia-east2",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "site": "vcf-lvlup",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/**",
        "destination": "https://vcf-lvlup.vercel.app/:splat",
        "type": 301
      }
    ]
  },
  "auth": {
    "providers": {
      "anonymous": true,
      "emailPassword": true
    }
  }
}