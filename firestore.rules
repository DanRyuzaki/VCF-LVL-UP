rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------
    // Helper functions
    // ----------------------------------------------------------------

    // Get the Firestore role of any user by UID
    function getRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    // Convenience: role of the currently authenticated caller
    function callerRole() {
      return getRole(request.auth.uid);
    }

    // ----------------------------------------------------------------
    // users/{uid}
    // ----------------------------------------------------------------
    match /users/{uid} {

      // Anyone authenticated can read their own document.
      // Admins and Developers can read any user document.
      allow read: if request.auth != null
        && (request.auth.uid == uid
            || callerRole() in ["admin", "developer"]);

      // ── CREATE ──
      // Rules: who can create whom, and what fields are locked.
      allow create: if request.auth != null
        && (
          // Developer creates Admin
          (callerRole() == "developer"
            && request.resource.data.role == "admin")

          // Admin creates Organizer
          || (callerRole() == "admin"
              && request.resource.data.role == "organizer")

          // Admin creates Gamer — gamerType MUST be free_agent
          || (callerRole() == "admin"
              && request.resource.data.role == "gamer"
              && request.resource.data.gamerType == "free_agent")
        )
        // Regardless of who creates, these fields must be locked at creation:
        // - createdBy must equal the caller's UID
        && request.resource.data.createdBy == request.auth.uid
        // - status must start as active or inactive (never suspended)
        && request.resource.data.status in ["active", "inactive"];

      // ── UPDATE ──
      // Users can update their own non-sensitive profile fields.
      // Admins/Developers can update status of accounts they manage.
      // Nobody can self-promote their role or self-suspend.
      allow update: if request.auth != null
        && (
          // Self-update: only allow safe profile fields
          (request.auth.uid == uid
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(["role", "gamerType", "createdBy", "createdAt"]))

          // Admin can update organizer/gamer status and safe fields
          || (callerRole() == "admin"
              && resource.data.role in ["organizer", "gamer"]
              // Prevent admin from elevating roles
              && request.resource.data.role == resource.data.role)

          // Developer can update admin status and safe fields
          || (callerRole() == "developer"
              && resource.data.role == "admin"
              && request.resource.data.role == resource.data.role)

          // Organizer can update gamerType for gamers they draft
          // (team_leader / team_member promotion via draft flow)
          || (callerRole() == "organizer"
              && resource.data.role == "gamer"
              // Only allow gamerType changes, teamId, inGameName
              && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(["gamerType", "teamId", "inGameName", "lastLogin"]))
        );

      // ── DELETE ──
      // Only admin (for organizer/gamer) or developer (for admin) can delete.
      allow delete: if request.auth != null
        && (
          (callerRole() == "admin"    && resource.data.role in ["organizer", "gamer"])
          || (callerRole() == "developer" && resource.data.role == "admin")
        );
    }

    // ----------------------------------------------------------------
    // deleted_user_reports/{reportId}
    // ----------------------------------------------------------------
    match /deleted_user_reports/{reportId} {
      // Admin and developer can read reports
      allow read: if request.auth != null
        && callerRole() in ["admin", "developer"];

      // Only admin/developer can create reports (written during delete flow)
      allow create: if request.auth != null
        && callerRole() in ["admin", "developer"]
        && request.resource.data.adminUid == request.auth.uid;

      // Reports are immutable once written
      allow update, delete: if false;
    }

    // ----------------------------------------------------------------
    // role_permissions/{role}  — static reference docs, read-only
    // ----------------------------------------------------------------
    match /role_permissions/{role} {
      allow read: if request.auth != null;
      // Only writable via Firebase console / admin SDK (seeding)
      allow write: if false;
    }

    // ----------------------------------------------------------------
    // audit_logs/{logId}  — append-only
    // ----------------------------------------------------------------
    match /audit_logs/{logId} {
      allow read: if request.auth != null
        && callerRole() in ["admin", "developer"];
      // Any authenticated user can append a log (e.g. lastLogin update)
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ----------------------------------------------------------------
    // All other documents — deny by default
    // ----------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
